// Rentgen.az — dental rentgen / 3D tomoqrafiya platforması
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------- Enums -----------------------------

enum Role {
  PATIENT
  CENTER
  DOCTOR
  ASSISTANT
  ADMIN
}

enum CenterStatus {
  PENDING // gözləmədə
  APPROVED // təsdiqlənib
  DEACTIVATED // deaktiv edilib
}

enum RequestStatus {
  NEW
  CONTACTED
  COMPLETED
  CANCELLED
}

enum ReferralStatus {
  NEW
  CONTACTED
  COMPLETED
}

// Abunə paketi (mərkəz və həkim üçün). FREE = defolt.
enum Plan {
  FREE
  SILVER
  GOLD
  PLATINUM
}

// ----------------------------- Core -----------------------------

model User {
  id          String    @id @default(cuid())
  phone       String    @unique // normalized +994XXXXXXXXX
  role        Role      @default(PATIENT)
  isBlocked   Boolean   @default(false)
  locale      String? // seçilmiş dil (az/ru); login-də tətbiq olunur
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  patientProfile PatientProfile?
  assistantOf    CenterAssistant?
  doctorAssistantOf DoctorAssistant?
  centerProfile  CenterProfile?
  doctorProfile  DoctorProfile?
  adminLogs      AdminActionLog[] @relation("AdminUser")
  notifications  Notification[]
  adminThread    AdminThread?
  wallet         Wallet?
  payments       Payment[]

  @@index([role])
}

// Prepaid balans (coin rail). Ödəniş top-up ilə artır, plan alışı ilə azalır.
model Wallet {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int            @default(0) // qəpik
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  ledger    WalletLedger[]
}

model WalletLedger {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount    Int // qəpik: +top-up / -alış
  type      String // TOPUP | PLAN | REFUND | ADMIN
  note      String?
  createdAt DateTime @default(now())

  @@index([walletId])
}

// Admin ↔ istifadəçi (həkim/mərkəz) söhbəti. Hər userin bir admin-söhbəti olur.
model AdminThread {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime       @default(now())
  userReadAt    DateTime? // user bu ana qədər oxuyub
  adminReadAt   DateTime? // admin bu ana qədər oxuyub
  createdAt     DateTime       @default(now())
  messages      AdminMessage[]

  @@index([lastMessageAt])
}

// Ödəniş (Payriff). Məbləğ qəpiklə (Int): 2000 = 20.00 AZN.
model Payment {
  id             String    @id @default(cuid())
  userId         String? // kim ödəyir (qonaq üçün null ola bilər)
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount         Int // qəpik
  currency       String    @default("AZN")
  purpose        String // "subscription" | "featured" | ... (Faza 2-də model təyin edir)
  status         String    @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  payriffOrderId String?   @unique
  transactionId  String?
  meta           Json?
  createdAt      DateTime  @default(now())
  paidAt         DateTime?

  @@index([userId])
  @@index([status])
}

model AdminMessage {
  id        String      @id @default(cuid())
  threadId  String
  thread    AdminThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fromAdmin Boolean // true = admin göndərib, false = user göndərib
  content   String
  fileUrl   String? // əlavə edilmiş fayl (şəkil/PDF)
  fileName  String? // faylın orijinal adı
  createdAt DateTime    @default(now())

  @@index([threadId, createdAt])
}

// Daxili bildirişlər (mərkəz/həkim/pasiyent). type: NEW_REQUEST | RESULT_READY
// | PARTNER_REQUEST | PARTNER_ACCEPTED | PARTNER_REJECTED | ADMIN_MESSAGE | PATIENT_UPDATED
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String? // klikləyəndə keçəcək daxili yol
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model PatientProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String?
  lastName  String?
  city      String?
  district  String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  favoriteCenters     CenterProfile[]      @relation("PatientFavorites")
  appointmentRequests AppointmentRequest[]
  reviews             Review[]
}

model CenterProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  slug              String       @unique
  phone             String
  whatsapp          String?
  address           String?
  city              String?
  district          String?
  mapsUrl           String?
  lat               Float?
  lng               Float?
  workingHours      String? // insan-oxunaqlı xülasə (strukturdan avtomatik yaranır)
  hours             Json? // strukturlaşdırılmış həftəlik iş saatları {mon:{open,close}|null,...}
  equipment         String? // avadanlıq məlumatı (mətn)
  responsiblePerson String?
  description       String?
  logoUrl           String? // mərkəzin loqosu (yüklənmiş şəkil)
  licenseUrl        String? // rentgenologiya üzrə lisenziya (məcburi)
  images            String[]     @default([])
  bannerUrl         String? // Platinum brendinq banneri
  status            CenterStatus @default(PENDING)
  plan              Plan         @default(FREE)
  planUntil         DateTime? // abunənin bitmə tarixi (ödəniş fazasında)
  // Ödənişli plan bitib FREE-yə düşdüyü an. 3 ay ərzində yenilənməsə, saxlanan
  // fayllar silinir. Yeniləmədə null olur.
  planExpiredAt     DateTime?
  apiKey            String?      @unique // Platinum API girişi açarı

  // Google rating (fetched via the platform's Places API key from googlePlaceId)
  googlePlaceId     String?
  googleRating      Float?
  googleReviewCount Int?
  googleRatingAt    DateTime?
  // Platinum: +1 TB storage blokları (hər blok 30 gün, OVERAGE_PER_TB_MINOR).
  extraStorageTb    Int          @default(0)
  extraStorageUntil DateTime? // blokların qüvvədə olma tarixi; keçibsə effektiv 0
  // CRM slot/randevu ayarları (crm.rentgen.az). slotBookingEnabled aktiv olanda
  // pasiyentlər saytda real boş slotları görüb birbaşa yazılır; əks halda köhnə
  // sərbəst-mətn randevu rejimi işləyir (default — mövcud mərkəzlər pozulmur).
  slotBookingEnabled Boolean     @default(false)
  slotMinutes        Int         @default(30) // slot uzunluğu (dəqiqə)
  slotCapacity       Int         @default(1) // bir slotda maksimum pasiyent sayı
  // Təkrarlanan nahar fasiləsi (CRM). Doldurularsa seçilmiş günlərdə bu aralıq
  // avtomatik bloklanır — hər gün ayrıca blok yaratmağa ehtiyac qalmır.
  lunchStart         String? // "HH:mm"
  lunchEnd           String? // "HH:mm"
  lunchDays          String[] @default([]) // ["mon","tue",...] — naharın tətbiq olunduğu günlər
  // CRM: randevu xatırlatması. Aktiv olanda cron pasiyentə randevudan
  // reminderHours saat əvvəl SMS xatırlatma göndərir (default söndürülü).
  remindersEnabled   Boolean  @default(false)
  reminderHours      Int      @default(24)
  // CRM SMS krediti: mərkəzin öz SMS-ləri (xatırlatma/çağırış/dəvət/kampaniya)
  // bu balansdan düşür. Platforma SMS-ləri (OTP, randevu bildirişi) toxunmur.
  smsBalance         Int      @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  services            CenterService[]
  appointmentRequests AppointmentRequest[]
  referrals           Referral[]
  favoritedBy         PatientProfile[]     @relation("PatientFavorites")
  reviews             Review[]
  events              CenterEvent[]
  doctorPartners      CenterDoctor[]
  conversations       Conversation[]
  workplaceDoctors    DoctorProfile[] @relation("DoctorWorkplace")
  timeBlocks          CenterTimeBlock[]
  holidays            CenterHoliday[]
  assistants          CenterAssistant[]
  smsCredits          CenterSmsCredit[]
  smsOrders           CenterSmsOrder[]

  @@index([status])
  @@index([city])
}

// CRM SMS balans yüklənmələri (hədiyyə və ya alış). Xərclənmə ayrıca yazılmır —
// hər göndəriş SmsLog-da (centerId ilə) qeyd olunur, balans smsBalance-dadır.
model CenterSmsCredit {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  amount    Int // əlavə olunan SMS sayı
  kind      String // "GRANT" (hədiyyə) | "PURCHASE" (alış)
  note      String?
  createdAt DateTime      @default(now())

  @@index([centerId])
}

// CRM SMS paketi sifarişi. Mərkəz sifariş verir → admin ödənişi təsdiqləyəndə
// balans yüklənir (Payriff qoşulana qədər manual axın).
model CenterSmsOrder {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  qty       Int // SMS sayı
  price     Int // AZN
  status    String        @default("PENDING") // PENDING | PAID | CANCELLED
  createdAt DateTime      @default(now())
  paidAt    DateTime?

  @@index([centerId])
  @@index([status])
}

// CRM: center-declared non-working days (holidays / days off). The whole day is
// blocked — no slots, no bookings. Managed as a list in CRM settings.
// CRM: mərkəz asistenti — mərkəz adından CRM-də gündəlik iş görür (randevu,
// pasiyent, fayl). Heç bir public səhifədə görünmür; Ayarlar/ödənişlər yalnız
// sahibə açıqdır. Giriş: crm.rentgen.az/giris (yalnız nömrə + OTP).
model CenterAssistant {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  @@index([centerId])
}

model DoctorAssistant {
  id        String        @id @default(cuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  @@index([doctorId])
}

model CenterHoliday {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  date      String // "YYYY-MM-DD" (Baku)
  reason    String?
  createdAt DateTime      @default(now())

  @@unique([centerId, date])
  @@index([centerId])
}

// CRM: center-created unavailable time ranges (breaks, lunch, holidays). These
// block slots the same way an appointment does (no patient attached).
model CenterTimeBlock {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime      @default(now())

  @@index([centerId, startAt])
}

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  shortName   String?
  description String?
  icon        String? // lucide icon adı (yüklənmiş ikon yoxdursa ehtiyat)
  iconUrl     String? // admin tərəfindən yüklənmiş xüsusi ikon (şəkil URL)
  category    String?
  order       Int     @default(0)
  featured    Boolean @default(false) // ana səhifə/footer-də vurğulanır
  isActive    Boolean @default(true)

  centerServices CenterService[]

  @@index([isActive])
}

model CenterService {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price       Int? // AZN
  priceTo     Int? // qiymət aralığı üçün yuxarı hədd
  durationMin Int  @default(30) // xidmətin göstərilmə müddəti (dəq) — CRM slot bloklaması
  note        String?

  @@unique([centerId, serviceId])
  @@index([serviceId])
}

model OTPCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String // sha256(code + secret)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  ip        String?
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Referral {
  id          String         @id @default(cuid())
  doctorName  String
  clinic      String?
  doctorPhone String
  patientName String
  examType    String
  note        String?
  centerId    String?
  center      CenterProfile? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  status      ReferralStatus @default(NEW)
  createdAt   DateTime       @default(now())

  @@index([centerId])
  @@index([status])
}

model AppointmentRequest {
  id            String          @id @default(cuid())
  patientId     String?
  patient       PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  name          String
  phone         String
  centerId      String?
  center        CenterProfile?  @relation(fields: [centerId], references: [id], onDelete: SetNull)
  doctorId      String?
  doctor        DoctorProfile?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  serviceSlug   String?
  note          String?
  preferredDate DateTime?
  status         RequestStatus  @default(NEW)
  completedBy    String? // "CENTER" | "PATIENT" — kim "xidmət alındı" işarələyib
  patientUpdated Boolean        @default(false) // pasiyent vaxtı dəyişib — mərkəz yenidən əlaqə saxlamalı
  resultUrl      String? // rentgen faylının linki (köhnə: xarici link)
  resultAddedAt  DateTime?
  reminderSentAt DateTime? // CRM randevu xatırlatma SMS-i göndərilib (dedup üçün)
  files          RentgenFile[]
  createdAt     DateTime        @default(now())

  @@index([centerId])
  @@index([doctorId])
  @@index([status])
  @@index([preferredDate])
}

// Rentgen faylı (Backblaze B2-də saxlanılır; bazada yalnız metadata).
model RentgenFile {
  id           String             @id @default(cuid())
  requestId    String
  request      AppointmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  key          String             @unique // B2 obyekt açarı (private)
  fileName     String
  size         Int // bayt (Faza 1: ≤ 2 GB)
  contentType  String
  uploadedById String? // yükləyən User.id
  createdAt    DateTime           @default(now())
  // Zibil qutusu (soft-delete). deletedAt != null → zibildə. purgeAt tarixində
  // cron faylı B2-dən həmişəlik silir. Saxlama müddəti plana bağlıdır.
  deletedAt    DateTime? // zibil qutusuna atılıb (null = aktiv)
  deletedById  String? // silən User.id
  purgeAt      DateTime? // bu tarixdə həmişəlik silinəcək

  @@index([requestId])
  @@index([purgeAt])
}

// Fayl əməliyyatlarının audit jurnalı (medical data — kim, nə vaxt, nə etdi).
model FileAuditLog {
  id        String   @id @default(cuid())
  action    String // UPLOAD | DOWNLOAD | DELETE
  fileId    String?
  requestId String?
  userId    String?
  role      String?
  fileName  String?
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([userId])
}

model Review {
  id        String         @id @default(cuid())
  centerId  String
  center    CenterProfile  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rating    Int // 1..5 (5 alt-balın ortası)
  comment   String?
  verified  Boolean        @default(false) // təsdiqlənmiş müştəri
  photos      String[]       @default([]) // pasiyentin əlavə etdiyi şəkillər
  hidden    Boolean        @default(false) // admin moderasiyası (gizlədilib)
  flagged   Boolean        @default(false) // avtomatik moderasiya — admin təsdiqini gözləyir
  reply     String? // mərkəzin cavabı
  repliedAt DateTime?

  // Walk-in (QR) rəyləri
  source       String  @default("appointment") // "appointment" | "qr"
  scoreService Int? // xidmətin ümumi keyfiyyəti
  scoreStaff   Int? // personalın münasibəti
  scoreClean   Int? // təmizlik / rahatlıq
  scoreWait    Int? // gözləmə vaxtı
  scorePrice   Int? // qiymət / dəyər nisbəti
  doctorId     String? // göndərən həkim (sistemdən) — göstərilmir
  doctorName   String? // göndərən həkim (əl ilə) — göstərilmir

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([centerId, patientId])
  @@index([centerId, hidden])
  @@index([flagged])
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  kind      String // "otp" | "center_request" | "patient_status" | "reminder" | "other"
  text      String // göndərilən mətn (OTP kodu maskalanır)
  ok        Boolean
  error     String?
  provider  String // "lsim" | "dev" | ...
  centerId  String? // CRM SMS-i — hansı mərkəzin balansından gedib
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([kind])
  @@index([centerId])
}

// OTP alan zaman seçilmiş qeydiyyat tipi. Yarımçıq qalan qeydiyyatları izləmək
// üçün: admin hansı tip profil (həkim/mərkəz/pasiyent) yaratmaq istəyib amma
// tamamlamayıb görür və istifadəçi ilə əlaqə saxlaya bilir.
model SignupAttempt {
  id        String   @id @default(cuid())
  phone     String
  role      String // "PATIENT" | "CENTER" | "DOCTOR" (niyyət)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, role])
  @@index([updatedAt])
}

model CenterEvent {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  type      String // "view" | "call" | "whatsapp"
  createdAt DateTime      @default(now())

  @@index([centerId, type, createdAt])
}

model DoctorProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  clinic          String? // iş yeri / klinika
  specialization  String? // (köhnə — sərbəst mətn, istifadə olunmur)
  specializations String[]     @default([]) // seçilmiş ixtisaslar
  portfolio       String[]     @default([]) // iş nümunələri (Silver+ brendinq)
  city            String?
  photoUrl        String? // profil şəkli
  bannerUrl       String? // Platinum brendinq banneri (public profildə)
  instagram       String?
  website         String?
  diplomaUrl      String?
  certificateUrl  String?
  residencyUrl    String? // rezidentura sənədi
  internshipUrl   String? // internatura sənədi
  specialtyUrl    String? // uzmanlıq sənədi
  status          CenterStatus @default(PENDING)
  // false = QR göndərişi ilə yaranan minimal qaralama profil (qeydiyyat tamamlanmayıb).
  // Tam qeydiyyatdan (/hekim/qeydiyyat) sonra true olur.
  onboarded       Boolean      @default(true)
  // İş yeri = sistemdə qeydiyyatlı mərkəz (mərkəz təsdiqindən sonra profildə link olur)
  workplaceCenterId String?
  workplaceCenter   CenterProfile? @relation("DoctorWorkplace", fields: [workplaceCenterId], references: [id], onDelete: SetNull)
  workplaceStatus   String? // PENDING | ACCEPTED | REJECTED
  plan            Plan         @default(FREE)
  planUntil       DateTime? // abunənin bitmə tarixi (ödəniş fazasında)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  appointmentRequests AppointmentRequest[]
  centerPartners      CenterDoctor[]
  conversations       Conversation[]
  events              DoctorEvent[]
  assistants          DoctorAssistant[]

  @@index([status])
  @@index([workplaceCenterId, workplaceStatus])
}

model DoctorEvent {
  id        String        @id @default(cuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  type      String // "view"
  createdAt DateTime      @default(now())

  @@index([doctorId, type, createdAt])
}

// Həkim↔mərkəz söhbəti (həmişə 2 tərəf). Mesajlar polling ilə yenilənir.
model Conversation {
  id            String        @id @default(cuid())
  centerId      String
  center        CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  messages      Message[]

  @@unique([centerId, doctorId])
  @@index([centerId, lastMessageAt])
  @@index([doctorId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String // göndərənin User.id
  senderRole     String // CENTER | DOCTOR
  content        String
  fileUrl        String? // əlavə edilmiş fayl (şəkil/PDF)
  fileName       String? // faylın orijinal adı
  readAt         DateTime? // qarşı tərəf oxuyanda
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

enum PartnerStatus {
  PENDING // həkim sorğu göndərib, mərkəz gözləyir
  ACCEPTED // mərkəz qəbul edib
  REJECTED // mərkəz rədd edib
}

// Mərkəz ↔ həkim əməkdaşlığı. Həkim sorğu göndərir, mərkəz qəbul/rədd edir.
model CenterDoctor {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status    PartnerStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([centerId, doctorId])
  @@index([centerId, status])
  @@index([doctorId, status])
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  content         String // markdown
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  tags            String[]  @default([])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
}

model City {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  order    Int     @default(0)
  isActive Boolean @default(true)
}

model SeoSetting {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String?
  description String?
  ogImage     String?
  updatedAt   DateTime @updatedAt
}

// Early-access demand signal capture from the bilingual /waitlist landing page.
// Deliberately separate from User/PatientProfile — no auth, no health data.
model WaitlistSignup {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  city      String?
  audience  String? // "patient" | "doctor" | "center" | null
  locale    String   @default("az") // "az" | "ru" — language the visitor used
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([locale])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String?
  admin      User?    @relation("AdminUser", fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

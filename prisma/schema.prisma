// Rentgen.az βÄî dental rentgen / 3D tomoqrafiya platformasΡ±
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------- Enums -----------------------------

enum Role {
  PATIENT
  CENTER
  DOCTOR
  ADMIN
}

enum CenterStatus {
  PENDING // gΟΕzl…ôm…ôd…ô
  APPROVED // t…ôsdiql…ônib
  DEACTIVATED // deaktiv edilib
}

enum RequestStatus {
  NEW
  CONTACTED
  COMPLETED
  CANCELLED
}

enum ReferralStatus {
  NEW
  CONTACTED
  COMPLETED
}

// ----------------------------- Core -----------------------------

model User {
  id          String    @id @default(cuid())
  phone       String    @unique // normalized +994XXXXXXXXX
  role        Role      @default(PATIENT)
  isBlocked   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  patientProfile PatientProfile?
  centerProfile  CenterProfile?
  doctorProfile  DoctorProfile?
  adminLogs      AdminActionLog[] @relation("AdminUser")

  @@index([role])
}

model PatientProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String?
  lastName  String?
  city      String?
  district  String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  favoriteCenters     CenterProfile[]      @relation("PatientFavorites")
  appointmentRequests AppointmentRequest[]
  reviews             Review[]
}

model CenterProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  slug              String       @unique
  phone             String
  whatsapp          String?
  address           String?
  city              String?
  district          String?
  mapsUrl           String?
  lat               Float?
  lng               Float?
  workingHours      String? // insan-oxunaqlΡ± xΟΦlas…ô (strukturdan avtomatik yaranΡ±r)
  hours             Json? // strukturla≈üdΡ±rΡ±lmΡ±≈ü h…ôft…ôlik i≈ü saatlarΡ± {mon:{open,close}|null,...}
  equipment         String? // avadanlΡ±q m…ôlumatΡ± (m…ôtn)
  responsiblePerson String?
  description       String?
  logoUrl           String? // m…ôrk…ôzin loqosu (yΟΦkl…ônmi≈ü ≈ü…ôkil)
  images            String[]     @default([])
  status            CenterStatus @default(PENDING)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  services            CenterService[]
  appointmentRequests AppointmentRequest[]
  referrals           Referral[]
  favoritedBy         PatientProfile[]     @relation("PatientFavorites")
  reviews             Review[]
  events              CenterEvent[]
  doctorPartners      CenterDoctor[]

  @@index([status])
  @@index([city])
}

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  shortName   String?
  description String?
  icon        String? // lucide icon adΡ± (yΟΦkl…ônmi≈ü ikon yoxdursa ehtiyat)
  iconUrl     String? // admin t…ôr…ôfind…ôn yΟΦkl…ônmi≈ü xΟΦsusi ikon (≈ü…ôkil URL)
  category    String?
  order       Int     @default(0)
  featured    Boolean @default(false) // ana s…ôhif…ô/footer-d…ô vurΡüulanΡ±r
  isActive    Boolean @default(true)

  centerServices CenterService[]

  @@index([isActive])
}

model CenterService {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Int? // AZN
  priceTo   Int? // qiym…ôt aralΡ±ΡüΡ± ΟΦΟßΟΦn yuxarΡ± h…ôdd
  note      String?

  @@unique([centerId, serviceId])
  @@index([serviceId])
}

model OTPCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String // sha256(code + secret)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  ip        String?
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Referral {
  id          String         @id @default(cuid())
  doctorName  String
  clinic      String?
  doctorPhone String
  patientName String
  examType    String
  note        String?
  centerId    String?
  center      CenterProfile? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  status      ReferralStatus @default(NEW)
  createdAt   DateTime       @default(now())

  @@index([centerId])
  @@index([status])
}

model AppointmentRequest {
  id            String          @id @default(cuid())
  patientId     String?
  patient       PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  name          String
  phone         String
  centerId      String?
  center        CenterProfile?  @relation(fields: [centerId], references: [id], onDelete: SetNull)
  doctorId      String?
  doctor        DoctorProfile?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  serviceSlug   String?
  note          String?
  preferredDate DateTime?
  status        RequestStatus   @default(NEW)
  completedBy   String? // "CENTER" | "PATIENT" βÄî kim "xidm…ôt alΡ±ndΡ±" i≈üar…ôl…ôyib
  createdAt     DateTime        @default(now())

  @@index([centerId])
  @@index([doctorId])
  @@index([status])
}

model Review {
  id        String         @id @default(cuid())
  centerId  String
  center    CenterProfile  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rating    Int // 1..5 (5 alt-balΡ±n ortasΡ±)
  comment   String?
  verified  Boolean        @default(false) // t…ôsdiql…ônmi≈ü mΟΦ≈üt…ôri
  hidden    Boolean        @default(false) // admin moderasiyasΡ± (gizl…ôdilib)
  flagged   Boolean        @default(false) // avtomatik moderasiya βÄî admin t…ôsdiqini gΟΕzl…ôyir
  reply     String? // m…ôrk…ôzin cavabΡ±
  repliedAt DateTime?

  // Walk-in (QR) r…ôyl…ôri
  source       String  @default("appointment") // "appointment" | "qr"
  scoreService Int? // xidm…ôtin ΟΦmumi keyfiyy…ôti
  scoreStaff   Int? // personalΡ±n mΟΦnasib…ôti
  scoreClean   Int? // t…ômizlik / rahatlΡ±q
  scoreWait    Int? // gΟΕzl…ôm…ô vaxtΡ±
  scorePrice   Int? // qiym…ôt / d…ôy…ôr nisb…ôti
  doctorId     String? // gΟΕnd…ôr…ôn h…ôkim (sistemd…ôn) βÄî gΟΕst…ôrilmir
  doctorName   String? // gΟΕnd…ôr…ôn h…ôkim (…ôl il…ô) βÄî gΟΕst…ôrilmir

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([centerId, patientId])
  @@index([centerId, hidden])
  @@index([flagged])
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  kind      String // "otp" | "center_request" | "patient_status" | "other"
  text      String // gΟΕnd…ôril…ôn m…ôtn (OTP kodu maskalanΡ±r)
  ok        Boolean
  error     String?
  provider  String // "lsim" | "dev" | ...
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([kind])
}

model CenterEvent {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  type      String // "view" | "call" | "whatsapp"
  createdAt DateTime      @default(now())

  @@index([centerId, type, createdAt])
}

model DoctorProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  clinic          String? // i≈ü yeri / klinika
  specialization  String? // (kΟΕhn…ô βÄî s…ôrb…ôst m…ôtn, istifad…ô olunmur)
  specializations String[]     @default([]) // seΟßilmi≈ü ixtisaslar
  city            String?
  instagram       String?
  website         String?
  diplomaUrl      String?
  certificateUrl  String?
  status          CenterStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  appointmentRequests AppointmentRequest[]
  centerPartners      CenterDoctor[]

  @@index([status])
}

enum PartnerStatus {
  PENDING // h…ôkim sorΡüu gΟΕnd…ôrib, m…ôrk…ôz gΟΕzl…ôyir
  ACCEPTED // m…ôrk…ôz q…ôbul edib
  REJECTED // m…ôrk…ôz r…ôdd edib
}

// M…ôrk…ôz βÜî h…ôkim …ôm…ôkda≈ülΡ±ΡüΡ±. H…ôkim sorΡüu gΟΕnd…ôrir, m…ôrk…ôz q…ôbul/r…ôdd edir.
model CenterDoctor {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status    PartnerStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([centerId, doctorId])
  @@index([centerId, status])
  @@index([doctorId, status])
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  content         String // markdown
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  tags            String[]  @default([])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
}

model City {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  order    Int     @default(0)
  isActive Boolean @default(true)
}

model SeoSetting {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String?
  description String?
  ogImage     String?
  updatedAt   DateTime @updatedAt
}

// Early-access demand signal capture from the bilingual /waitlist landing page.
// Deliberately separate from User/PatientProfile βÄî no auth, no health data.
model WaitlistSignup {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  city      String?
  audience  String? // "patient" | "doctor" | "center" | null
  locale    String   @default("az") // "az" | "ru" βÄî language the visitor used
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([locale])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String?
  admin      User?    @relation("AdminUser", fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

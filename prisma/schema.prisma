// Rentgen.az ‚Äî dental rentgen / 3D tomoqrafiya platformasƒ±
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------- Enums -----------------------------

enum Role {
  PATIENT
  CENTER
  DOCTOR
  ADMIN
}

enum CenterStatus {
  PENDING // g√∂zl…ôm…ôd…ô
  APPROVED // t…ôsdiql…ônib
  DEACTIVATED // deaktiv edilib
}

enum RequestStatus {
  NEW
  CONTACTED
  COMPLETED
  CANCELLED
}

enum ReferralStatus {
  NEW
  CONTACTED
  COMPLETED
}

// Abun…ô paketi (m…ôrk…ôz v…ô h…ôkim √º√ß√ºn). FREE = defolt.
enum Plan {
  FREE
  SILVER
  GOLD
  PLATINUM
}

// ----------------------------- Core -----------------------------

model User {
  id          String    @id @default(cuid())
  phone       String    @unique // normalized +994XXXXXXXXX
  role        Role      @default(PATIENT)
  isBlocked   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  patientProfile PatientProfile?
  centerProfile  CenterProfile?
  doctorProfile  DoctorProfile?
  adminLogs      AdminActionLog[] @relation("AdminUser")
  notifications  Notification[]
  adminThread    AdminThread?
  wallet         Wallet?

  @@index([role])
}

// Prepaid balans (coin rail). √ñd…ôni≈ü top-up il…ô artƒ±r, plan alƒ±≈üƒ± il…ô azalƒ±r.
model Wallet {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int            @default(0) // q…ôpik
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  ledger    WalletLedger[]
}

model WalletLedger {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount    Int // q…ôpik: +top-up / -alƒ±≈ü
  type      String // TOPUP | PLAN | REFUND | ADMIN
  note      String?
  createdAt DateTime @default(now())

  @@index([walletId])
}

// Admin ‚Üî istifad…ô√ßi (h…ôkim/m…ôrk…ôz) s√∂hb…ôti. H…ôr userin bir admin-s√∂hb…ôti olur.
model AdminThread {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime       @default(now())
  userReadAt    DateTime? // user bu ana q…ôd…ôr oxuyub
  adminReadAt   DateTime? // admin bu ana q…ôd…ôr oxuyub
  createdAt     DateTime       @default(now())
  messages      AdminMessage[]

  @@index([lastMessageAt])
}

// √ñd…ôni≈ü (Payriff). M…ôbl…ôƒü q…ôpikl…ô (Int): 2000 = 20.00 AZN.
model Payment {
  id             String    @id @default(cuid())
  userId         String? // kim √∂d…ôyir (qonaq √º√ß√ºn null ola bil…ôr)
  amount         Int // q…ôpik
  currency       String    @default("AZN")
  purpose        String // "subscription" | "featured" | ... (Faza 2-d…ô model t…ôyin edir)
  status         String    @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  payriffOrderId String?   @unique
  transactionId  String?
  meta           Json?
  createdAt      DateTime  @default(now())
  paidAt         DateTime?

  @@index([userId])
  @@index([status])
}

model AdminMessage {
  id        String      @id @default(cuid())
  threadId  String
  thread    AdminThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fromAdmin Boolean // true = admin g√∂nd…ôrib, false = user g√∂nd…ôrib
  content   String
  createdAt DateTime    @default(now())

  @@index([threadId, createdAt])
}

// Daxili bildiri≈ül…ôr (m…ôrk…ôz/h…ôkim/pasiyent). type: NEW_REQUEST | RESULT_READY
// | PARTNER_REQUEST | PARTNER_ACCEPTED | PARTNER_REJECTED | ADMIN_MESSAGE | PATIENT_UPDATED
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String? // klikl…ôy…ônd…ô ke√ß…ôc…ôk daxili yol
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model PatientProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String?
  lastName  String?
  city      String?
  district  String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  favoriteCenters     CenterProfile[]      @relation("PatientFavorites")
  appointmentRequests AppointmentRequest[]
  reviews             Review[]
}

model CenterProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  slug              String       @unique
  phone             String
  whatsapp          String?
  address           String?
  city              String?
  district          String?
  mapsUrl           String?
  lat               Float?
  lng               Float?
  workingHours      String? // insan-oxunaqlƒ± x√ºlas…ô (strukturdan avtomatik yaranƒ±r)
  hours             Json? // strukturla≈üdƒ±rƒ±lmƒ±≈ü h…ôft…ôlik i≈ü saatlarƒ± {mon:{open,close}|null,...}
  equipment         String? // avadanlƒ±q m…ôlumatƒ± (m…ôtn)
  responsiblePerson String?
  description       String?
  logoUrl           String? // m…ôrk…ôzin loqosu (y√ºkl…ônmi≈ü ≈ü…ôkil)
  licenseUrl        String? // rentgenologiya √ºzr…ô lisenziya (m…ôcburi)
  images            String[]     @default([])
  bannerUrl         String? // Platinum brendinq banneri
  status            CenterStatus @default(PENDING)
  plan              Plan         @default(FREE)
  planUntil         DateTime? // abun…ônin bitm…ô tarixi (√∂d…ôni≈ü fazasƒ±nda)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  services            CenterService[]
  appointmentRequests AppointmentRequest[]
  referrals           Referral[]
  favoritedBy         PatientProfile[]     @relation("PatientFavorites")
  reviews             Review[]
  events              CenterEvent[]
  doctorPartners      CenterDoctor[]
  conversations       Conversation[]
  workplaceDoctors    DoctorProfile[] @relation("DoctorWorkplace")

  @@index([status])
  @@index([city])
}

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  shortName   String?
  description String?
  icon        String? // lucide icon adƒ± (y√ºkl…ônmi≈ü ikon yoxdursa ehtiyat)
  iconUrl     String? // admin t…ôr…ôfind…ôn y√ºkl…ônmi≈ü x√ºsusi ikon (≈ü…ôkil URL)
  category    String?
  order       Int     @default(0)
  featured    Boolean @default(false) // ana s…ôhif…ô/footer-d…ô vurƒüulanƒ±r
  isActive    Boolean @default(true)

  centerServices CenterService[]

  @@index([isActive])
}

model CenterService {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Int? // AZN
  priceTo   Int? // qiym…ôt aralƒ±ƒüƒ± √º√ß√ºn yuxarƒ± h…ôdd
  note      String?

  @@unique([centerId, serviceId])
  @@index([serviceId])
}

model OTPCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String // sha256(code + secret)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  ip        String?
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Referral {
  id          String         @id @default(cuid())
  doctorName  String
  clinic      String?
  doctorPhone String
  patientName String
  examType    String
  note        String?
  centerId    String?
  center      CenterProfile? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  status      ReferralStatus @default(NEW)
  createdAt   DateTime       @default(now())

  @@index([centerId])
  @@index([status])
}

model AppointmentRequest {
  id            String          @id @default(cuid())
  patientId     String?
  patient       PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  name          String
  phone         String
  centerId      String?
  center        CenterProfile?  @relation(fields: [centerId], references: [id], onDelete: SetNull)
  doctorId      String?
  doctor        DoctorProfile?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  serviceSlug   String?
  note          String?
  preferredDate DateTime?
  status         RequestStatus  @default(NEW)
  completedBy    String? // "CENTER" | "PATIENT" ‚Äî kim "xidm…ôt alƒ±ndƒ±" i≈üar…ôl…ôyib
  patientUpdated Boolean        @default(false) // pasiyent vaxtƒ± d…ôyi≈üib ‚Äî m…ôrk…ôz yenid…ôn …ôlaq…ô saxlamalƒ±
  resultUrl      String? // rentgen faylƒ±nƒ±n linki (k√∂hn…ô: xarici link)
  resultAddedAt  DateTime?
  files          RentgenFile[]
  createdAt     DateTime        @default(now())

  @@index([centerId])
  @@index([doctorId])
  @@index([status])
}

// Rentgen faylƒ± (Backblaze B2-d…ô saxlanƒ±lƒ±r; bazada yalnƒ±z metadata).
model RentgenFile {
  id           String             @id @default(cuid())
  requestId    String
  request      AppointmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  key          String             @unique // B2 obyekt a√ßarƒ± (private)
  fileName     String
  size         Int // bayt (Faza 1: ‚â§ 2 GB)
  contentType  String
  uploadedById String? // y√ºkl…ôy…ôn User.id
  createdAt    DateTime           @default(now())

  @@index([requestId])
}

// Fayl …ôm…ôliyyatlarƒ±nƒ±n audit jurnalƒ± (medical data ‚Äî kim, n…ô vaxt, n…ô etdi).
model FileAuditLog {
  id        String   @id @default(cuid())
  action    String // UPLOAD | DOWNLOAD | DELETE
  fileId    String?
  requestId String?
  userId    String?
  role      String?
  fileName  String?
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([userId])
}

model Review {
  id        String         @id @default(cuid())
  centerId  String
  center    CenterProfile  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rating    Int // 1..5 (5 alt-balƒ±n ortasƒ±)
  comment   String?
  verified  Boolean        @default(false) // t…ôsdiql…ônmi≈ü m√º≈üt…ôri
  hidden    Boolean        @default(false) // admin moderasiyasƒ± (gizl…ôdilib)
  flagged   Boolean        @default(false) // avtomatik moderasiya ‚Äî admin t…ôsdiqini g√∂zl…ôyir
  reply     String? // m…ôrk…ôzin cavabƒ±
  repliedAt DateTime?

  // Walk-in (QR) r…ôyl…ôri
  source       String  @default("appointment") // "appointment" | "qr"
  scoreService Int? // xidm…ôtin √ºmumi keyfiyy…ôti
  scoreStaff   Int? // personalƒ±n m√ºnasib…ôti
  scoreClean   Int? // t…ômizlik / rahatlƒ±q
  scoreWait    Int? // g√∂zl…ôm…ô vaxtƒ±
  scorePrice   Int? // qiym…ôt / d…ôy…ôr nisb…ôti
  doctorId     String? // g√∂nd…ôr…ôn h…ôkim (sistemd…ôn) ‚Äî g√∂st…ôrilmir
  doctorName   String? // g√∂nd…ôr…ôn h…ôkim (…ôl il…ô) ‚Äî g√∂st…ôrilmir

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([centerId, patientId])
  @@index([centerId, hidden])
  @@index([flagged])
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  kind      String // "otp" | "center_request" | "patient_status" | "other"
  text      String // g√∂nd…ôril…ôn m…ôtn (OTP kodu maskalanƒ±r)
  ok        Boolean
  error     String?
  provider  String // "lsim" | "dev" | ...
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([kind])
}

model CenterEvent {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  type      String // "view" | "call" | "whatsapp"
  createdAt DateTime      @default(now())

  @@index([centerId, type, createdAt])
}

model DoctorProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  clinic          String? // i≈ü yeri / klinika
  specialization  String? // (k√∂hn…ô ‚Äî s…ôrb…ôst m…ôtn, istifad…ô olunmur)
  specializations String[]     @default([]) // se√ßilmi≈ü ixtisaslar
  city            String?
  photoUrl        String? // profil ≈ü…ôkli
  instagram       String?
  website         String?
  diplomaUrl      String?
  certificateUrl  String?
  residencyUrl    String? // rezidentura s…ôn…ôdi
  internshipUrl   String? // internatura s…ôn…ôdi
  specialtyUrl    String? // uzmanlƒ±q s…ôn…ôdi
  status          CenterStatus @default(PENDING)
  // ƒ∞≈ü yeri = sistemd…ô qeydiyyatlƒ± m…ôrk…ôz (m…ôrk…ôz t…ôsdiqind…ôn sonra profild…ô link olur)
  workplaceCenterId String?
  workplaceCenter   CenterProfile? @relation("DoctorWorkplace", fields: [workplaceCenterId], references: [id], onDelete: SetNull)
  workplaceStatus   String? // PENDING | ACCEPTED | REJECTED
  plan            Plan         @default(FREE)
  planUntil       DateTime? // abun…ônin bitm…ô tarixi (√∂d…ôni≈ü fazasƒ±nda)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  appointmentRequests AppointmentRequest[]
  centerPartners      CenterDoctor[]
  conversations       Conversation[]
  events              DoctorEvent[]

  @@index([status])
  @@index([workplaceCenterId, workplaceStatus])
}

model DoctorEvent {
  id        String        @id @default(cuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  type      String // "view"
  createdAt DateTime      @default(now())

  @@index([doctorId, type, createdAt])
}

// H…ôkim‚Üîm…ôrk…ôz s√∂hb…ôti (h…ômi≈ü…ô 2 t…ôr…ôf). Mesajlar polling il…ô yenil…ônir.
model Conversation {
  id            String        @id @default(cuid())
  centerId      String
  center        CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  messages      Message[]

  @@unique([centerId, doctorId])
  @@index([centerId, lastMessageAt])
  @@index([doctorId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String // g√∂nd…ôr…ônin User.id
  senderRole     String // CENTER | DOCTOR
  content        String
  readAt         DateTime? // qar≈üƒ± t…ôr…ôf oxuyanda
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

enum PartnerStatus {
  PENDING // h…ôkim sorƒüu g√∂nd…ôrib, m…ôrk…ôz g√∂zl…ôyir
  ACCEPTED // m…ôrk…ôz q…ôbul edib
  REJECTED // m…ôrk…ôz r…ôdd edib
}

// M…ôrk…ôz ‚Üî h…ôkim …ôm…ôkda≈ülƒ±ƒüƒ±. H…ôkim sorƒüu g√∂nd…ôrir, m…ôrk…ôz q…ôbul/r…ôdd edir.
model CenterDoctor {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status    PartnerStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([centerId, doctorId])
  @@index([centerId, status])
  @@index([doctorId, status])
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  content         String // markdown
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  tags            String[]  @default([])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
}

model City {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  order    Int     @default(0)
  isActive Boolean @default(true)
}

model SeoSetting {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String?
  description String?
  ogImage     String?
  updatedAt   DateTime @updatedAt
}

// Early-access demand signal capture from the bilingual /waitlist landing page.
// Deliberately separate from User/PatientProfile ‚Äî no auth, no health data.
model WaitlistSignup {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  city      String?
  audience  String? // "patient" | "doctor" | "center" | null
  locale    String   @default("az") // "az" | "ru" ‚Äî language the visitor used
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([locale])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String?
  admin      User?    @relation("AdminUser", fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

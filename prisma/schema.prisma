// Rentgen.az — dental rentgen / 3D tomoqrafiya platforması
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------- Enums -----------------------------

enum Role {
  PATIENT
  CENTER
  DOCTOR
  ADMIN
}

enum CenterStatus {
  PENDING // gözləmədə
  APPROVED // təsdiqlənib
  DEACTIVATED // deaktiv edilib
}

enum RequestStatus {
  NEW
  CONTACTED
  COMPLETED
  CANCELLED
}

enum ReferralStatus {
  NEW
  CONTACTED
  COMPLETED
}

// ----------------------------- Core -----------------------------

model User {
  id          String    @id @default(cuid())
  phone       String    @unique // normalized +994XXXXXXXXX
  role        Role      @default(PATIENT)
  isBlocked   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  patientProfile PatientProfile?
  centerProfile  CenterProfile?
  doctorProfile  DoctorProfile?
  adminLogs      AdminActionLog[] @relation("AdminUser")
  notifications  Notification[]
  adminThread    AdminThread?

  @@index([role])
}

// Admin ↔ istifadəçi (həkim/mərkəz) söhbəti. Hər userin bir admin-söhbəti olur.
model AdminThread {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime       @default(now())
  userReadAt    DateTime? // user bu ana qədər oxuyub
  adminReadAt   DateTime? // admin bu ana qədər oxuyub
  createdAt     DateTime       @default(now())
  messages      AdminMessage[]

  @@index([lastMessageAt])
}

model AdminMessage {
  id        String      @id @default(cuid())
  threadId  String
  thread    AdminThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fromAdmin Boolean // true = admin göndərib, false = user göndərib
  content   String
  createdAt DateTime    @default(now())

  @@index([threadId, createdAt])
}

// Daxili bildirişlər (mərkəz/həkim/pasiyent). type: NEW_REQUEST | RESULT_READY
// | PARTNER_REQUEST | PARTNER_ACCEPTED | PARTNER_REJECTED | ADMIN_MESSAGE | PATIENT_UPDATED
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String? // klikləyəndə keçəcək daxili yol
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model PatientProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String?
  lastName  String?
  city      String?
  district  String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  favoriteCenters     CenterProfile[]      @relation("PatientFavorites")
  appointmentRequests AppointmentRequest[]
  reviews             Review[]
}

model CenterProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  slug              String       @unique
  phone             String
  whatsapp          String?
  address           String?
  city              String?
  district          String?
  mapsUrl           String?
  lat               Float?
  lng               Float?
  workingHours      String? // insan-oxunaqlı xülasə (strukturdan avtomatik yaranır)
  hours             Json? // strukturlaşdırılmış həftəlik iş saatları {mon:{open,close}|null,...}
  equipment         String? // avadanlıq məlumatı (mətn)
  responsiblePerson String?
  description       String?
  logoUrl           String? // mərkəzin loqosu (yüklənmiş şəkil)
  licenseUrl        String? // rentgenologiya üzrə lisenziya (məcburi)
  images            String[]     @default([])
  status            CenterStatus @default(PENDING)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  services            CenterService[]
  appointmentRequests AppointmentRequest[]
  referrals           Referral[]
  favoritedBy         PatientProfile[]     @relation("PatientFavorites")
  reviews             Review[]
  events              CenterEvent[]
  doctorPartners      CenterDoctor[]
  conversations       Conversation[]

  @@index([status])
  @@index([city])
}

model Service {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  shortName   String?
  description String?
  icon        String? // lucide icon adı (yüklənmiş ikon yoxdursa ehtiyat)
  iconUrl     String? // admin tərəfindən yüklənmiş xüsusi ikon (şəkil URL)
  category    String?
  order       Int     @default(0)
  featured    Boolean @default(false) // ana səhifə/footer-də vurğulanır
  isActive    Boolean @default(true)

  centerServices CenterService[]

  @@index([isActive])
}

model CenterService {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Int? // AZN
  priceTo   Int? // qiymət aralığı üçün yuxarı hədd
  note      String?

  @@unique([centerId, serviceId])
  @@index([serviceId])
}

model OTPCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String // sha256(code + secret)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  ip        String?
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Referral {
  id          String         @id @default(cuid())
  doctorName  String
  clinic      String?
  doctorPhone String
  patientName String
  examType    String
  note        String?
  centerId    String?
  center      CenterProfile? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  status      ReferralStatus @default(NEW)
  createdAt   DateTime       @default(now())

  @@index([centerId])
  @@index([status])
}

model AppointmentRequest {
  id            String          @id @default(cuid())
  patientId     String?
  patient       PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  name          String
  phone         String
  centerId      String?
  center        CenterProfile?  @relation(fields: [centerId], references: [id], onDelete: SetNull)
  doctorId      String?
  doctor        DoctorProfile?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  serviceSlug   String?
  note          String?
  preferredDate DateTime?
  status         RequestStatus  @default(NEW)
  completedBy    String? // "CENTER" | "PATIENT" — kim "xidmət alındı" işarələyib
  patientUpdated Boolean        @default(false) // pasiyent vaxtı dəyişib — mərkəz yenidən əlaqə saxlamalı
  resultUrl      String? // rentgen faylının linki (köhnə: xarici link)
  resultAddedAt  DateTime?
  files          RentgenFile[]
  createdAt     DateTime        @default(now())

  @@index([centerId])
  @@index([doctorId])
  @@index([status])
}

// Rentgen faylı (Backblaze B2-də saxlanılır; bazada yalnız metadata).
model RentgenFile {
  id           String             @id @default(cuid())
  requestId    String
  request      AppointmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  key          String             @unique // B2 obyekt açarı (private)
  fileName     String
  size         Int // bayt (Faza 1: ≤ 2 GB)
  contentType  String
  uploadedById String? // yükləyən User.id
  createdAt    DateTime           @default(now())

  @@index([requestId])
}

// Fayl əməliyyatlarının audit jurnalı (medical data — kim, nə vaxt, nə etdi).
model FileAuditLog {
  id        String   @id @default(cuid())
  action    String // UPLOAD | DOWNLOAD | DELETE
  fileId    String?
  requestId String?
  userId    String?
  role      String?
  fileName  String?
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([userId])
}

model Review {
  id        String         @id @default(cuid())
  centerId  String
  center    CenterProfile  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rating    Int // 1..5 (5 alt-balın ortası)
  comment   String?
  verified  Boolean        @default(false) // təsdiqlənmiş müştəri
  hidden    Boolean        @default(false) // admin moderasiyası (gizlədilib)
  flagged   Boolean        @default(false) // avtomatik moderasiya — admin təsdiqini gözləyir
  reply     String? // mərkəzin cavabı
  repliedAt DateTime?

  // Walk-in (QR) rəyləri
  source       String  @default("appointment") // "appointment" | "qr"
  scoreService Int? // xidmətin ümumi keyfiyyəti
  scoreStaff   Int? // personalın münasibəti
  scoreClean   Int? // təmizlik / rahatlıq
  scoreWait    Int? // gözləmə vaxtı
  scorePrice   Int? // qiymət / dəyər nisbəti
  doctorId     String? // göndərən həkim (sistemdən) — göstərilmir
  doctorName   String? // göndərən həkim (əl ilə) — göstərilmir

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([centerId, patientId])
  @@index([centerId, hidden])
  @@index([flagged])
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  kind      String // "otp" | "center_request" | "patient_status" | "other"
  text      String // göndərilən mətn (OTP kodu maskalanır)
  ok        Boolean
  error     String?
  provider  String // "lsim" | "dev" | ...
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([kind])
}

model CenterEvent {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  type      String // "view" | "call" | "whatsapp"
  createdAt DateTime      @default(now())

  @@index([centerId, type, createdAt])
}

model DoctorProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  clinic          String? // iş yeri / klinika
  specialization  String? // (köhnə — sərbəst mətn, istifadə olunmur)
  specializations String[]     @default([]) // seçilmiş ixtisaslar
  city            String?
  photoUrl        String? // profil şəkli
  instagram       String?
  website         String?
  diplomaUrl      String?
  certificateUrl  String?
  residencyUrl    String? // rezidentura sənədi
  internshipUrl   String? // internatura sənədi
  specialtyUrl    String? // uzmanlıq sənədi
  status          CenterStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  appointmentRequests AppointmentRequest[]
  centerPartners      CenterDoctor[]
  conversations       Conversation[]

  @@index([status])
}

// Həkim↔mərkəz söhbəti (həmişə 2 tərəf). Mesajlar polling ilə yenilənir.
model Conversation {
  id            String        @id @default(cuid())
  centerId      String
  center        CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  messages      Message[]

  @@unique([centerId, doctorId])
  @@index([centerId, lastMessageAt])
  @@index([doctorId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String // göndərənin User.id
  senderRole     String // CENTER | DOCTOR
  content        String
  readAt         DateTime? // qarşı tərəf oxuyanda
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

enum PartnerStatus {
  PENDING // həkim sorğu göndərib, mərkəz gözləyir
  ACCEPTED // mərkəz qəbul edib
  REJECTED // mərkəz rədd edib
}

// Mərkəz ↔ həkim əməkdaşlığı. Həkim sorğu göndərir, mərkəz qəbul/rədd edir.
model CenterDoctor {
  id        String        @id @default(cuid())
  centerId  String
  center    CenterProfile @relation(fields: [centerId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status    PartnerStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([centerId, doctorId])
  @@index([centerId, status])
  @@index([doctorId, status])
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  content         String // markdown
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  tags            String[]  @default([])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
}

model City {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  order    Int     @default(0)
  isActive Boolean @default(true)
}

model SeoSetting {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String?
  description String?
  ogImage     String?
  updatedAt   DateTime @updatedAt
}

// Early-access demand signal capture from the bilingual /waitlist landing page.
// Deliberately separate from User/PatientProfile — no auth, no health data.
model WaitlistSignup {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  city      String?
  audience  String? // "patient" | "doctor" | "center" | null
  locale    String   @default("az") // "az" | "ru" — language the visitor used
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([locale])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String?
  admin      User?    @relation("AdminUser", fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

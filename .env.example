# ----------------------------------------------------------------------------
# Rentgen.az — Environment variables
# Copy this file to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# --- Database (PostgreSQL — Supabase / Neon / Vercel Postgres) ---
# Pooled connection (used by the app at runtime). Supabase: port 6543, ?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations). Supabase: port 5432
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Auth / sessions ---
# Long random string. Generate with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-secret-string-min-32-chars"
# Extra secret used to hash OTP codes before storing them.
OTP_SECRET="change-me-too-another-long-random-secret"

# --- Public site URL (used for canonical URLs, sitemap, OG) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- SMS / OTP provider ---
# Provider: "dev" (logs OTP to server console — no real SMS, good for local/testing),
#           "twilio", or "generic" (any HTTP SMS gateway, e.g. an Azerbaijani provider).
SMS_PROVIDER="dev"

# Twilio (only if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Generic HTTP SMS gateway (only if SMS_PROVIDER=generic)
# The body is sent as JSON: { to, message } with optional bearer token / api key.
SMS_GENERIC_URL=""
SMS_GENERIC_TOKEN=""
SMS_GENERIC_SENDER=""

# --- Bootstrap admin ---
# Phone number (any format) that is auto-granted ADMIN role on first login.
ADMIN_PHONE="+994500000000"
# Secret admin access link. Visit /admin-giris/<ADMIN_ACCESS_KEY> to get admin
# access (not linked anywhere on the site). Use a long random value.
ADMIN_ACCESS_KEY="change-me-to-a-long-random-secret"
# Optional 2FA: when "true", the secret link also emails a one-time code that
# must be entered. Enable ONLY after NOTIFY_EMAIL delivery works (else lockout).
ADMIN_2FA="false"

# --- Notifications (new appointment requests / doctor referrals) ---
# Email that receives notifications when a request/referral is submitted.
NOTIFY_EMAIL="you@example.com"
# Provider: "formsubmit" (free, no API key — needs one-time activation click),
#           "resend" (RESEND_API_KEY required), or "console" (logs only).
EMAIL_PROVIDER="formsubmit"
# Resend (only if EMAIL_PROVIDER=resend)
RESEND_API_KEY=""
RESEND_FROM="Rentgen.az <onboarding@resend.dev>"
